{
  "manifest_version": 3,
  "name": "Twitter 1-Minute Timer",
  "version": "1.0",
  "description": "1分経つとTwitterをブロックする拡張",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
